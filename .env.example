# Tushare 备用数据源 Token（从 https://tushare.pro 注册获取）
TUSHARE_TOKEN=your_tushare_token_here

# CORS 允许的前端地址（逗号分隔，用于生产环境）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM 配置（用于 AI 深度分析报告，至少配置一种）────────────────────────────
# LLM_PROVIDER: "anthropic"（默认，使用 Claude）| "openai"（使用 OpenAI 或兼容接口）
LLM_PROVIDER=anthropic

# ── Claude（Anthropic）────────────────────────────────────────────────────────
# 从 https://console.anthropic.com 获取
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 可选，默认 claude-sonnet-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# ── OpenAI / 兼容接口（DeepSeek 等）─────────────────────────────────────────
# LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
# 可选，默认 gpt-4o
OPENAI_MODEL=gpt-4o
# 可选，兼容 DeepSeek 等 OpenAI 格式接口
# OPENAI_BASE_URL=https://api.deepseek.com/v1
